<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>Log in</title>
</head>
<body>
    <%- include('layout'); %>
    <h1 class="text-center" id="page-prompt">Log in to your Bookfest account!</h1>
    <form action="/users/login" method="post">
        <div class="form-row justify-content-md-center mb-3">
            <div class="mb-1">
            <input autocomplete="off" autofocus class="form-control mx-auto w-auto" name="email" placeholder="Email" required type="email">
        </div>
        </div>
        <div class="mb-4 mt-1">
            <input class="form-control mx-auto w-auto" name="password" placeholder="Password" required type="password">
        </div>
        </div>
        </div>
        <div class="d-flex justify-content-center">
            <button class="btn btn-primary" type="submit">Log in</button>
        </div>
    </form>
</body>
</html>