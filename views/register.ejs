<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>Register</title>
</head>
<body>
    <%- include('layout'); %>
    <h1 class="text-center" id="page-prompt">Sign up for a Bookfest account!</h1>
    <form action="/users/register" method="post">
        <div class="form-row justify-content-md-center mb-3">
            <div class="form-col" mb-3>
            <input autocomplete="off" autofocus class="form-control mx-auto w-auto" name="firstName" placeholder="First Name" required type="text">
        </div>
        <div class="mb-3">
            <input class="form-control mx-auto w-auto" name="lastName" placeholder="Last Name" required type="text">
        </div>
        </div>
        <div class="mb-3">
            <input class="form-control mx-auto w-auto" name="email" placeholder="Email" required type="email">
        </div>
        <div class="mb-3">
            <input class="form-control mx-auto w-auto" name="password" placeholder="Password" required type="password">
        </div>
        <div class="mb-3">
            <input class="form-control mx-auto w-auto" name="confirmation" placeholder="Confirm Password" required type="password">
        </div>
        </div>
        <div class="d-flex justify-content-center">
            <button class="btn btn-primary" type="submit">Register</button>
        </div>
    </form>
</body>
</html>